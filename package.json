{
  "name": "rgbbox",
  "version": "0.1.0",
  "description": "Local-first desktop RGB lighting controller with multi-display screen sampling.",
  "author": "RGBBox Contributors",
  "homepage": "https://github.com/tjf/RGBBox",
  "license": "MIT",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "yarn typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "yarn typecheck:node && yarn typecheck:web",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "dist": "yarn build && electron-builder",
    "dist:win": "yarn build && electron-builder --win",
    "dist:mac": "yarn build && electron-builder --mac",
    "dist:dir": "yarn build && electron-builder --dir"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "electron": "latest",
    "electron-builder": "latest",
    "electron-vite": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "build": {
    "appId": "app.rgbbox.desktop",
    "productName": "RGBBox",
    "copyright": "Copyright © 2025 RGBBox Contributors",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "build/icon.png",
      "category": "Utility"
    }
  }
}
